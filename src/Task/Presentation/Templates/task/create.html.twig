{% extends 'base.html.twig' %}

{% block body %}

    <div class="container py-5">

        <h1>
            Create Task
        </h1>

        {{ form_start(form) }}

        {{ form_row(form.title) }}

        {{ form_row(form.nextAction) }}

        <button
            type="submit"
            class="btn btn-primary"
        >
            Create
        </button>

        {{ form_end(form) }}

    </div>

{% endblock %}
