{% extends 'base.html.twig' %}

{% block body %}

    <div class="container py-5">

        <h1>
            Focus OS
        </h1>

        {% if task %}

            <div class="card mt-4">

                <div class="card-body">

                    <h2>
                        Current Task
                    </h2>

                    <h3>
                        {{ task.title }}
                    </h3>

                    <p>
                        {{ task.nextAction }}
                    </p>

                </div>

            </div>

        {% else %}

            <div class="alert alert-secondary mt-4">

                No active task

            </div>

        {% endif %}

        <a
            href="{{ path('task_create') }}"
            class="btn btn-primary mt-3"
        >
            Create Task
        </a>

    </div>

{% endblock %}
