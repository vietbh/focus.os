<?xml version="1.0" encoding="UTF-8"?>

<doctrine-mapping
    xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://doctrine-project.org/schemas/orm/doctrine-mapping
        https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd"
>

    <entity
        name="App\Identity\Domain\Entity\User"
        table="users"
    >

        <id
            name="id"
            type="user_id"
            column="id"
        >
            <generator strategy="NONE"/>
        </id>

        <field
            name="email"
            type="string"
            column="email"
            length="255"
        />

        <field
            name="name"
            type="string"
            column="name"
            length="255"
        />

        <field
            name="avatar"
            type="string"
            column="avatar"
            nullable="true"
            length="1000"
        />

        <field
            name="provider"
            enum-type="App\Identity\Domain\Enum\AuthProvider"
            column="provider"
        />

        <field
            name="providerId"
            type="string"
            column="provider_id"
            length="255"
        />

        <field
            name="createdAt"
            type="datetime_immutable"
            column="created_at"
        />

        <field
            name="updatedAt"
            type="datetime_immutable"
            column="updated_at"
        />

        <unique-constraints>
            <unique-constraint
                name="uniq_user_provider"
                columns="provider,provider_id"
            />
        </unique-constraints>

        <indexes>
            <index
                name="idx_user_email"
                columns="email"
            />
        </indexes>

    </entity>

</doctrine-mapping>
